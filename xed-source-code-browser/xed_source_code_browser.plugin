[Plugin]
Loader=python3
Module=xed_source_code_browser
IAge=3
Name=Xed Source Code Browser
Description=Shows a tree of symbols (functions, classes, variables, etc.) for the active document using ctags.
Authors=Gabriell Araujo (Xed port); based on Pluma plugin by Micah Carrick and MATE Developers
